{
  "name": "podcasthub-api",
  "version": "1.0.0",
  "description": "PodcastHub API con JWT, roles, Swagger y tests con Jest",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=.env src/index.js",
    "start": "node --env-file=.env src/index.js",
    "test": "node --env-file=.env --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --forceExit --detectOpenHandles",
    "test:watch": "npm test -- --watch",
    "test:coverage": "npm test -- --coverage"
  },
  "keywords": [
    "swagger",
    "jest",
    "slack",
    "nodejs",
    "express",
    "podcasts",
    "jwt"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@slack/webhook": "^7.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan-body": "^2.6.9",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
